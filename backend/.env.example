# 复制为 .env 填写。默认 provider 见 LLM_PROVIDER。
LLM_PROVIDER=claude          # claude | qwen | minimax | glm

# Claude（Anthropic）
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Qwen3（阿里云 DashScope，OpenAI 兼容）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-max

# MiniMax 2.7（OpenAI 兼容）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=minimax-2.7

# GLM 5.2（智谱，OpenAI 兼容）
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5.2

# 排料求解时限（秒）
NEST_TIME_SEC=20
