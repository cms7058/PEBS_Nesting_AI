# docker compose 用环境变量。复制为 .env(与 docker-compose.yml 同级)后填写。
# 这些 LLM key 也可不填,启动后在前端「⚙ 模型配置」页填写并持久化。

# 前端对外端口(共享服务器上改成未被占用的端口,如 18080)
FRONTEND_PORT=8080

LLM_PROVIDER=claude          # claude | qwen | minimax | glm
CLAUDE_MODEL=claude-opus-4-8

ANTHROPIC_API_KEY=
QWEN_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=

# 排料求解时限(秒)
NEST_TIME_SEC=20

# PEBS 阿米巴上报(留空=独立模式,休眠)
AMIBA_ENDPOINT=
AMIBA_TOKEN=
